      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "finops-ledger"
          },
          "format": "table",
          "rawSql": "SELECT p.strategy_family AS `Methodology`, i.symbol AS `Symbol`, p.direction AS `Direction`, DATE_FORMAT(DATE_ADD(p.created_at, INTERVAL p.horizon_days DAY), '%d-%m-%Y') AS `Verdict due`, CONCAT(FORMAT(p.target_low_pct,1,'de_DE'), '% \u2013 ', FORMAT(p.target_high_pct,1,'de_DE'), '%') AS `Target return`, CONCAT(FORMAT(p.max_adverse_pct,1,'de_DE'), '%') AS `Dead beyond`, FORMAT(p.confidence,2,'de_DE') AS `Confidence`, p.catalyst AS `Catalyst` FROM finops_agora.predictions p JOIN finops_agora.instruments i ON i.id = p.instrument_id LEFT JOIN finops_agora.verdicts v ON v.plan_hash = p.plan_hash WHERE v.plan_hash IS NULL ORDER BY DATE_ADD(p.created_at, INTERVAL p.horizon_days DAY), p.strategy_family LIMIT 40"
        }
      ],
      "description": "Every row is a falsifiable promise with a hash. Nothing here is tradeable advice; shorts/longs are shadow bets graded against real prices."
    },
    {
      "type": "table",
      "title": "\ud83c\udfc6 Methodology scoreboard \u2014 who earns their keep (latest scoring)",
      "datasource": {
        "type": "mysql",
        "uid": "finops-ledger"
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": false
          },
          "noValue": "Awaiting first verdicts \u2014 due from 16-06-2026"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "md",
        "sortBy": [],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "finops-ledger"
          },
          "format": "table",
          "rawSql": "SELECT ss.family AS `Methodology`, COALESCE(st.status,'\u26a0 undeclared') AS `Status`, ss.n_verdicted AS `Graded`, CONCAT(ss.n_match,' / ',ss.n_partial,' / ',ss.n_deviation) AS `match / partial / deviation`, CONCAT(FORMAT(ss.win_rate*100,1,'de_DE'),'%') AS `Win rate`, CONCAT(FORMAT(ss.avg_excess_pct,2,'de_DE'),' pp') AS `Excess vs index`, FORMAT(ss.avg_brier,3,'de_DE') AS `Brier`, FORMAT(ss.calibration_gap,3,'de_DE') AS `Overconfidence` FROM finops_agora.strategy_scores ss JOIN (SELECT family, MAX(score_date) d FROM finops_agora.strategy_scores GROUP BY family) m   ON m.family = ss.family AND m.d = ss.score_date LEFT JOIN finops_agora.strategies st ON st.family = ss.family ORDER BY ss.avg_excess_pct DESC"
        }
      ],
      "description": "Win rate and excess-vs-index are NEVER collapsed into one number (omoikane Article LXXV pattern). Overconfidence = avg confidence minus win rate; positive means the methodology promises more than it delivers. Graduation gates read THIS table (DESIGN.md \u00a79)."
    },
