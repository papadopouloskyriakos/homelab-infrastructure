      "id": 1,
      "title": "CubeOS Pipeline Success Rate",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "project_pipeline_success_rate{project=\"cubeos\"}",
          "legendFormat": "CubeOS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
