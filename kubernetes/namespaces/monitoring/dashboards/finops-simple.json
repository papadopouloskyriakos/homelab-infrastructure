      "datasource": { "type": "mysql", "uid": "finops-ledger" },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "decimals": 2,
          "min": 0,
          "max": 5469.35,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#9DB8D8" },
              { "value": 4375, "color": "#6E8FB8" },
              { "value": 5469, "color": "#3F6196" }
