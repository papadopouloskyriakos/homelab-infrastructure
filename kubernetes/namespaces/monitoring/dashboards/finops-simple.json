      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "mysql", "uid": "finops-ledger" },
          "format": "table",
          "rawSql": "SELECT COALESCE(ROUND(SUM(CASE WHEN t.base_amount>0 AND c.kind='income' THEN t.base_amount END),2),0) v FROM transactions t LEFT JOIN categories c ON t.category=c.slug WHERE (t.account_id IN ('ing-checking','ing-card','paypal') OR (t.account_id LIKE 'ing-sav-%' AND t.account_id<>'ing-sav-k797')) AND t.booked_date>=DATE_FORMAT(CURDATE(),'%Y-%m-01')"
