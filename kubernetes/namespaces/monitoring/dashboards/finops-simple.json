      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "mysql", "uid": "finops-ledger" },
          "format": "table",
          "rawSql": "SELECT ROUND(-SUM(t.base_amount),2) FROM transactions t JOIN categories c ON t.category=c.slug WHERE c.kind='expense' AND (t.account_id IN ('ing-checking','ing-card','paypal') OR (t.account_id LIKE 'ing-sav-%' AND t.account_id<>'ing-sav-k797')) AND NOT (t.account_id='ing-checking' AND t.payee_raw LIKE '%Incasso ING creditcard%') AND t.booked_date>=DATE_FORMAT(CURDATE(),'%Y-%m-01')"
        }
      ]
    },
