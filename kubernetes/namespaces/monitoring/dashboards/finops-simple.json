      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "mysql", "uid": "finops-ledger" },
          "format": "table",
          "rawSql": "SELECT CASE t.category WHEN 'online-shopping' THEN 'Online shopping' WHEN 'card-spending' THEN 'Card bill' WHEN 'groceries' THEN 'Food (groceries)' WHEN 'mortgage' THEN 'Home (mortgage)' WHEN 'REDACTED_358be28b' THEN 'Apps & subscriptions' WHEN 'electronics-homelab' THEN 'Gear / electronics' WHEN 'takeaway-delivery' THEN 'Takeaway' WHEN 'loans' THEN 'Loan payments' WHEN 'electric-gas' THEN 'Electric & gas' WHEN 'greece-family' THEN 'Family (Greece)' WHEN 'internet-mobile' THEN 'Internet / mobile' WHEN 'supplements-fitness' THEN 'Supplements' WHEN 'health-insurance-nn' THEN 'Health insurance' WHEN 'water-dunea' THEN 'Water' ELSE t.category END AS `Where it goes`, ROUND(-SUM(t.base_amount),2) AS `Spent` FROM transactions t JOIN categories c ON t.category=c.slug WHERE c.kind='expense' AND (t.account_id IN ('ing-checking','ing-card','paypal') OR (t.account_id LIKE 'ing-sav-%' AND t.account_id<>'ing-sav-k797')) AND NOT (t.account_id='ing-checking' AND t.payee_raw LIKE '%Incasso ING creditcard%') AND t.booked_date>=DATE_FORMAT(CURDATE(),'%Y-%m-01') GROUP BY 1 ORDER BY 2 DESC LIMIT 5"
        }
      ]
    },

