          "format": "table",
          "rawSql": "SELECT DATE_FORMAT(booked_date,'%e %b') AS `When`, CONCAT('€ ',FORMAT(-base_amount,2,'de_DE')) AS Amount, LEFT(payee_raw,34) AS `Paid to` FROM transactions WHERE (account_id IN ('ing-checking','ing-card','paypal') OR (account_id LIKE 'ing-sav-%' AND account_id<>'ing-sav-k797')) AND base_amount<0 AND (category IS NULL OR category<>'transfer') AND booked_date>=DATE_FORMAT(CURDATE(),'%Y-%m-01') ORDER BY base_amount ASC LIMIT 8"
