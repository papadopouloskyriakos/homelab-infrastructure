    {
      "type": "barchart",
      "title": "\ud83d\uded2 Where my money goes (average per month, \u20ac)",
      "datasource": {
        "type": "mysql",
        "uid": "finops-ledger"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xField": "Where it goes",
        "showValue": "always",
        "barWidth": 0.8,
        "legend": {
          "showLegend": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "finops-ledger"
          },
          "format": "table",
          "rawSql": "SELECT CASE t.category WHEN 'online-shopping' THEN 'Online shopping' WHEN 'card-spending' THEN 'Paying credit card' WHEN 'groceries' THEN 'Food (groceries)' WHEN 'mortgage' THEN 'Home (mortgage)' WHEN 'REDACTED_358be28b' THEN 'Apps & subscriptions' WHEN 'electronics-homelab' THEN 'Gear / electronics' WHEN 'takeaway-delivery' THEN 'Takeaway' WHEN 'loans' THEN 'Loan payments' WHEN 'electric-gas' THEN 'Electric & gas' WHEN 'greece-family' THEN 'Family (Greece)' WHEN 'supplements-fitness' THEN 'Supplements' WHEN 'health-insurance-nn' THEN 'Health insurance' ELSE t.category END AS `Where it goes`, ROUND(-SUM(t.base_amount)/6,0) AS `Per month` FROM transactions t JOIN categories c ON t.category=c.slug WHERE c.kind='expense' AND (t.account_id IN ('ing-checking','ing-card') OR (t.account_id LIKE 'ing-sav-%' AND t.account_id<>'ing-sav-k797')) AND NOT (t.account_id='ing-checking' AND t.payee_raw LIKE '%Incasso ING creditcard%') AND t.booked_date>=DATE_SUB(CURDATE(),INTERVAL 6 MONTH) GROUP BY 1 ORDER BY 2 DESC LIMIT 10"
        }
      ]
    },
    {
      "type": "table",
      "title": "\ud83d\udccb My subscriptions (cancel what you don't use)",
      "datasource": {
        "type": "mysql",
        "uid": "finops-ledger"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mysql",
            "uid": "finops-ledger"
          },
          "format": "table",
          "rawSql": "SELECT LEFT(payee_raw,28) AS `Subscription`, CONCAT('\u20ac ', FORMAT(-SUM(base_amount)/6,2,'de_DE')) AS `Per month` FROM transactions WHERE category='REDACTED_358be28b' AND base_amount<0 AND (account_id IN ('ing-checking','ing-card') OR (account_id LIKE 'ing-sav-%' AND account_id<>'ing-sav-k797')) AND booked_date>=DATE_SUB(CURDATE(),INTERVAL 6 MONTH) GROUP BY 1 ORDER BY -SUM(base_amount) DESC LIMIT 12"
        }
      ]
    },
