{
  "title": "OTel Traces & Spans",
  "uid": "otel-traces",
  "tags": [
    "otel",
    "tracing",
    "chatops"
  ],
  "timezone": "utc",
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "title": "Traced Sessions",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "trace_sessions_total",
          "legendFormat": "Sessions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Spans (7d)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "trace_spans_7d",
          "legendFormat": "Spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "green",
                "value": 5000
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Span Error Rate (7d)",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "trace_span_errors_7d / trace_spans_7d",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Tool Latency p50 / p95 (ms)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "REDACTED_88776aba",
          "legendFormat": "p50"
        },
        {
          "expr": "REDACTED_edcb8b6f",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 5,
      "title": "Infrastructure Commands (7d)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "REDACTED_63efc4b5",
          "legendFormat": "Commands"
        }
      ]
    },
    {
      "id": 6,
      "title": "Devices Targeted (7d)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "expr": "REDACTED_85cfe296",
          "legendFormat": "Devices"
        }
      ]
    },
    {
      "id": 7,
      "title": "Tool Call Volume by Type",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "tool_calls_total",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ],
  "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
  },
  "schemaVersion": 39,
  "editable": true,
  "id": null
}